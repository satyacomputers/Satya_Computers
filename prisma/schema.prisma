generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Product {
  id              String   @id @default(cuid())
  name            String
  brand           String
  category        String   @default("Laptop")
  processor       String
  ram             String
  storage         String
  display         String?
  os              String?
  basePrice       Float?
  mrp             Float?
  price           Float
  bulkPrice5_10   Float?
  bulkPrice11_25  Float?
  bulkPrice26Plus Float?
  minOrderQty     Int      @default(1)
  stockStatus     String   @default("In Stock")
  image           String?
  gallery         String?  // Store as JSON stringified array of image URLs
  stock           Int      @default(0)
  description     String?
  isFeatured      Boolean  @default(false)
  warranty        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id             String   @id @default(cuid())
  orderId        String   @unique
  companyName    String
  contactPerson  String
  email          String
  phone          String
  products       String
  totalUnits     Int
  estimatedValue Float
  status         String   @default("Pending")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Offer {
  id          String    @id @default(cuid())
  type        String
  title       String
  description String?
  code        String?
  discount    Float?
  minOrder    Int?
  expiryDate  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  type      String
  status    String   @default("Live")
  date      String
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String?
  bio       String?
  email     String?
  linkedin  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  website   String?
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  image       String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("New")
  createdAt DateTime @default(now())
}

model CustomerOrder {
  id            String   @id @default(cuid())
  orderId       String   @unique
  customerName  String
  email         String
  phone         String
  address       String
  city          String?
  state         String?
  pincode       String?
  products      String   // Contains JSON array of { productId, name, price, quantity, image }
  totalAmount   Float
  paymentMethod String   // "COD" or "UPI"
  paymentStatus String   @default("Pending") // Pending, Paid
  orderStatus   String   @default("Processing") // Processing, Shipped, Delivered, Cancelled
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}